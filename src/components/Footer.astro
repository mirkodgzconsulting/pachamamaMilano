---
---
<footer class="bg-[#1a1a1a] text-white pt-16 pb-8 border-t border-white/5">
    <div class="container mx-auto px-4 max-w-7xl">
      <!-- Main Grid: 4 Columns -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 text-center mb-16">
        
        <!-- 1. Contact -->
        <div class="flex flex-col items-center">
          <div class="text-gold text-3xl mb-4">
             <!-- Phone Icon -->
             <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="currentColor" viewBox="0 0 24 24"><path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56a.977.977 0 00-1.01.24l-1.57 1.97c-2.83-1.44-5.15-3.75-6.59-6.59l1.97-1.57c.23-.23.33-.55.24-1.01a17.3 17.3 0 00-.56-3.53.995.995 0 00-1-.75h-3.5c-.55 0-1 .45-1 1C4.25 14.84 13.16 23.75 22 23.75c.55 0 1-.45 1-1v-3.5c0-.51-.41-.95-.91-.87h-.08z"/></svg>
          </div>
          <h3 class="font-display text-2xl tracking-wider mb-2">Contattaci</h3>
          <p class="text-gray-300 text-sm font-semibold">pachamamanovoandina@gmail.com</p>
          <p class="text-gray-300 text-sm font-semibold">328 428 1204</p>
          <p class="text-gray-300 text-sm font-semibold">02 39444119</p>
        </div>
  
        <!-- 2. Location -->
        <div class="flex flex-col items-center">
          <div class="text-gold text-3xl mb-4">
            <!-- Map Pin Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
          </div>
          <h3 class="font-display text-2xl tracking-wider mb-2">Vieni a trovarci</h3>
          <p class="text-gray-300 text-sm font-semibold">Via dei Tulipani 1, Milano</p>
        </div>
  
        <!-- 3. WhatsApp -->
        <div class="flex flex-col items-center">
            <div class="text-gold text-3xl mb-4">
                <!-- WhatsApp Icon -->
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="currentColor" viewBox="0 0 24 24"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91C2.13 13.66 2.59 15.36 3.45 16.86L2.05 22L7.3 20.62C8.75 21.41 10.38 21.83 12.04 21.83C17.5 21.83 21.95 17.38 21.95 11.92C21.95 9.27 20.92 6.78 19.05 4.91C17.18 3.03 14.69 2 12.04 2M12.05 3.67C14.25 3.67 16.31 4.53 17.87 6.09C19.42 7.65 20.28 9.72 20.28 11.92C20.28 16.46 16.58 20.15 12.04 20.15C10.56 20.15 9.11 19.76 7.85 19L7.55 18.83L4.43 19.65L5.26 16.61L5.06 16.29C4.24 14.99 3.81 13.47 3.81 11.91C3.81 7.37 7.5 3.67 12.05 3.67"/></svg>
            </div>
            <h3 class="font-display text-2xl tracking-wider mb-2">Prenota su WhatsApp</h3>
             <a href="#" class="text-gray-300 text-sm font-semibold hover:text-gold transition-colors">Clicca qui</a>
        </div>

        <!-- 4. Hours (Orari) -->
        <div class="flex flex-col items-center">
            <div class="text-gold text-3xl mb-4">
                <!-- Clock Icon -->
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="currentColor" viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
            </div>
            <h3 class="font-display text-2xl tracking-wider mb-2">Orari</h3>
            <div class="text-gray-300 text-sm font-semibold space-y-1 text-left inline-block">
                <div class="grid grid-cols-[80px_1fr] gap-x-2">
                    <span class="text-right">lunedì</span> <span>12–15:30, 17:30–23:30</span>
                    <span class="text-right">martedì</span> <span>12–15:30, 17:30–23:30</span>
                    <span class="text-right">mercoledì</span> <span>Chiuso</span>
                    <span class="text-right">giovedì</span> <span>12–15:30, 17:30–23:30</span>
                    <span class="text-right">venerdì</span> <span>12–15:30, 17:30–23:30</span>
                    <span class="text-right">sabato</span> <span>12:00 – 23:30</span>
                    <span class="text-right">domenica</span> <span>12:00 – 23:30</span>
                </div>
            </div>
        </div>
      </div>
  
      <!-- Decorative Pattern Strip -->
      <div class="w-full max-w-7xl mx-auto h-24 mb-8 bg-center" style="background-image: url('/images/home/pattern2.png'); background-repeat: no-repeat; background-size: contain;"></div>

      <!-- Social & Copyright -->
      <div class="text-center">
        <h4 class="font-body font-bold text-white mb-4">Seguici su</h4>
        <div class="flex justify-center gap-6 mb-8">
            <!-- Facebook -->
            <a href="https://www.facebook.com/ristorante.pachamama.milano/" target="_blank" class="bg-gold text-black p-2 rounded hover:bg-white hover:text-black transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <!-- Instagram -->
            <a href="https://www.instagram.com/pachamama_milano/" target="_blank" class="bg-gold text-black p-2 rounded hover:bg-white hover:text-black transition-colors">
