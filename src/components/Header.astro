---

---

<header
  class="bg-dark py-4 px-6 fixed top-0 w-full z-50 flex justify-between items-center border-b border-white/10"
>
  <a href="/" class="block">
    <!-- Logo Placeholder -->
    <img
      src="/logo.png"
      alt="Pachamama Milano"
      class="h-14 md:h-16 w-auto"
      onerror="this.src='https://placehold.co/150x50/black/gold?text=PACHAMAMA'"
    />
  </a>

  <!-- Horizontal Navigation - Professional & Clean (Desktop) -->
  <nav class="hidden lg:flex items-center justify-center gap-6">
    <a
      href="/"
      class="text-white hover:text-gold transition-colors font-display text-lg uppercase tracking-widest"
      >Home</a
    >
    <a
      href="/chi-siamo"
      class="text-white hover:text-gold transition-colors font-display text-lg uppercase tracking-widest"
      >Chi Siamo</a
    >
    <a
      href="/gallery"
      class="text-white hover:text-gold transition-colors font-display text-lg uppercase tracking-widest"
      >Gallery</a
    >
    <a
      href="/prenota"
      class="text-white hover:text-gold transition-colors font-display text-lg uppercase tracking-widest"
      >Prenota</a
    >
    <a
      href="/gift-card"
      class="text-white hover:text-gold transition-colors font-display text-lg uppercase tracking-widest"
      >Gift Card</a
    >

    <a
      href="https://drive.google.com/file/d/1wiAKFkQrQeHpsyeKyM0Yoo6uVNl5SqIy/view"
      target="_blank"
      class="text-white hover:text-gold transition-colors font-display text-lg uppercase tracking-widest"
      >Food</a
    >
    <a
      href="https://drive.google.com/file/d/1Ispo7H0L3CRMUnzbW5yFJHi4JD0mnImn/view"
      target="_blank"
      class="text-white hover:text-gold transition-colors font-display text-lg uppercase tracking-widest"
      >Bar</a
    >

    <!-- User Navigation -->
    <div
      id="user-nav-desktop"
      class="flex items-center gap-4 ml-4 pl-4 border-l border-white/10"
    >
      <a
        href="/area-cliente"
        class="bg-white/10 text-white text-[10px] font-bold py-2 px-4 rounded border border-white/20 uppercase tracking-widest hover:bg-gold hover:text-dark transition-all hidden"
        id="nav-orders-desktop">Area Cliente</a
      >
      <button
        id="nav-logout"
        class="bg-white/5 hover:bg-red-500/20 text-white text-[10px] font-bold py-2 px-4 rounded border border-white/10 uppercase tracking-widest transition-all hidden"
        >Logout</button
      >
      <a
        href="/area-cliente/login"
        class="bg-gold text-dark text-[10px] font-bold py-2 px-4 rounded uppercase tracking-widest hover:bg-white transition-all"
        id="nav-login">Login</a
      >
    </div>
  </nav>

  <!-- Mobile Menu Toggle Button -->
  <div class="flex items-center gap-4 lg:hidden">
    <!-- Mobile User Icon - Link directo al área cuando está logueado -->
    <a
      href="/area-cliente"
      class="text-gold hover:text-white transition-colors hidden"
      id="nav-area-cliente-mobile-icon"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
        ></path></svg
      >
    </a>
    <button
      id="menu-toggle"
      class="text-white hover:text-gold focus:outline-none z-50"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-8 w-8"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 bg-dark z-40 hidden flex-col items-center justify-center text-white p-10"
>
  <button
    id="menu-close"
    class="absolute top-6 right-6 text-white text-5xl hover:text-gold"
    >&times;</button
  >

  <nav class="flex flex-col gap-6 text-center w-full">
    <a
      href="/"
      class="text-2xl font-display uppercase tracking-widest hover:text-gold"
      >Home</a
    >
    <a
      href="/chi-siamo"
      class="text-2xl font-display uppercase tracking-widest hover:text-gold"
      >Chi Siamo</a
    >
    <a
      href="/gallery"
      class="text-2xl font-display uppercase tracking-widest hover:text-gold"
      >Gallery</a
    >
    <a
      href="/prenota"
      class="text-2xl font-display uppercase tracking-widest hover:text-gold"
      >Prenota</a
    >
    <a
      href="/gift-card"
      class="text-2xl font-display uppercase tracking-widest hover:text-gold"
      >Gift Card</a
    >
    <a
      href="/area-cliente"
      class="text-2xl font-display uppercase tracking-widest hover:text-gold hidden"
      id="mobile-nav-orders">Area Cliente</a
    >

    <div class="h-px bg-white/10 my-4"></div>

    <div id="mobile-auth-section" class="flex flex-col gap-4">
      <button
        id="mobile-nav-logout"
        class="text-red-400 text-2xl font-display uppercase tracking-widest hidden"
        >Logout</button
      >
      <a
        href="/area-cliente/login"
        class="text-gold text-2xl font-display uppercase tracking-widest"
        id="mobile-nav-login">Login</a
      >
    </div>
  </nav>
</div>

<script>
  import { supabase } from "../lib/supabase";

  const menuToggle = document.getElementById("menu-toggle");
  const menuClose = document.getElementById("menu-close");
  const mobileMenu = document.getElementById("mobile-menu");

  const desktopLogout = document.getElementById("nav-logout");
  const desktopLogin = document.getElementById("nav-login");
  const desktopOrders = document.getElementById("nav-orders-desktop");

  const mobileIcon = document.getElementById("nav-area-cliente-mobile-icon");
  const mobileLogout = document.getElementById("mobile-nav-logout");
  const mobileLogin = document.getElementById("mobile-nav-login");
  const mobileOrders = document.getElementById("mobile-nav-orders");

  async function updateAuthUI() {
    // 1. Verificación rápida local (Síncrona para velocidad)
    const guestEmail = localStorage.getItem("pachamama_guest_email");

    // 2. Verificación de sesión de Supabase (Asíncrona)
    const {
      data: { session },
    } = await supabase.auth.getSession();

    const isLoggedIn = !!session || !!guestEmail;

    if (isLoggedIn) {
      desktopLogout?.classList.remove("hidden");
      desktopLogin?.classList.add("hidden");
      desktopOrders?.classList.remove("hidden");

      mobileIcon?.classList.remove("hidden");
      mobileLogout?.classList.remove("hidden");
      mobileLogin?.classList.add("hidden");
      mobileOrders?.classList.remove("hidden");
    } else {
      desktopLogout?.classList.add("hidden");
      desktopLogin?.classList.remove("hidden");
      desktopOrders?.classList.add("hidden");

      mobileIcon?.classList.add("hidden");
      mobileLogout?.classList.add("hidden");
      mobileLogin?.classList.remove("hidden");
      mobileOrders?.classList.add("hidden");
    }
  }

  // Inicializar UI inmediatamente y también después de cargar Supabase
  updateAuthUI();

  desktopLogout?.addEventListener("click", async () => {
    await supabase.auth.signOut();
    localStorage.removeItem("pachamama_guest_email");
    window.location.href = "/";
  });

  mobileLogout?.addEventListener("click", async () => {
    await supabase.auth.signOut();
    localStorage.removeItem("pachamama_guest_email");
    window.location.href = "/";
  });

  menuToggle?.addEventListener("click", () =>
    mobileMenu?.classList.remove("hidden"),
  );
  menuClose?.addEventListener("click", () =>
    mobileMenu?.classList.add("hidden"),
  );

  // Escuchar cambios de fase
  supabase.auth.onAuthStateChange(() => {
    updateAuthUI();
  });
</script>
