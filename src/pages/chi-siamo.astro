---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SectionPattern from '../components/SectionPattern.astro';

const title = "Chi Siamo | Pachamama Milano";
---

<Layout title={title}>
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center justify-center bg-cover bg-center" style="background-image: url('/images/home/hero-bg.jpg');">
        <!-- Overlay -->
        <div class="absolute inset-0 bg-black/50"></div>
        
        <div class="relative z-10 text-center text-white px-4">
            <h1 class="text-5xl md:text-8xl font-display font-bold uppercase tracking-widest text-shadow-lg">Chi Siamo</h1>
            <div class="w-24 h-1 bg-gold mx-auto mt-4"></div>
        </div>
    </section>

    <!-- Content Section -->
    <section class="bg-white text-black pt-24 pb-2 px-4">
         <div class="container mx-auto max-w-4xl text-center">
            <!-- Tag - Clean Gold Style with Dark Background -->
            <span class="inline-block px-8 py-2 mb-6 text-xl tracking-widest text-[#FFD54F] bg-[#1F1F1F] font-display font-bold uppercase rounded-md shadow-lg">
                Pachamama Milano
            </span>
            
            <h2 class="text-3xl md:text-5xl font-display font-bold mb-8 uppercase text-black leading-tight">
                Il Primo Ristorante Novoandino <br/> a Milano
            </h2>

            <p class="text-xl md:text-2xl font-light leading-relaxed mb-8 text-gray-800">
                Siamo il primo <strong>ristorante a Milano</strong> dedicato alla <strong>cucina novoandina</strong>! 
                Scopri l’anima del Perù, lasciati sorprendere dai nostri sapori e vivi un’esperienza gastronomica indimenticabile!
            </p>
            
            <p class="text-lg text-gray-600 leading-relaxed mb-0">
                La nostra filosofia nasce dall'incontro tra le antiche tradizioni culinarie delle Ande e le tecniche contemporanee. 
                Ogni piatto racconta una storia di biodiversità, cultura e passione. Crediamo nell'uso di ingredienti autentici 
                per portarvi in un viaggio sensoriale unico nel cuore del Sud America, direttamente nel centro di Milano.
            </p>

         </div>
    </section>

    <SectionPattern />

  </main>
  
  <Footer />
</Layout>
