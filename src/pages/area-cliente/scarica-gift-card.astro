---
import Layout from "../../layouts/Layout.astro";
import { supabaseAdmin } from "../../lib/supabase";

import imgModel1 from "../../imagesgc/model1.webp";
import imgModel2 from "../../imagesgc/model2.webp";
import imgModel3 from "../../imagesgc/model3.webp";
import imgLogo from "../../imagesgc/logo.png";

const id = Astro.url.searchParams.get("id");

if (!id) {
  return Astro.redirect("/area-cliente");
}

let order = null;
try {
  const { data, error } = await supabaseAdmin
    .from("gift_cards")
    .select("*")
    .eq("id", id)
    .single();

  if (error || !data) throw new Error("Gift Card non trovata.");

  // Si no está confirmada, no deberíamos mostrarla o podríamos mostrarla con marca de agua, pero asumimos que lo está o es preview.
  order = data;
} catch (error) {
  console.error(error);
  return Astro.redirect("/area-cliente");
}

const title = "La tua Gift Card | Pachamama Milano";
---

<Layout title={title}>
  <div
    class="bg-gray-50 min-h-screen py-12 md:py-20 flex flex-col items-center"
  >
    <div class="max-w-4xl w-full px-4 flex flex-col items-center">
      <div class="text-center mb-8">
        <h1
          class="text-4xl md:text-5xl font-display text-dark uppercase tracking-widest mb-4"
        >
          La Tua Gift Card
        </h1>
        <p
          class="text-sm font-body text-gray-500 max-w-lg mx-auto leading-relaxed"
        >
          Ecco la tua Gift Card personalizzata. Clicca sul pulsante qui sotto
          per salvarla come immagine e inviarla a chi vuoi.
        </p>
      </div>

      <!-- CONTENEDOR DE LA GIFT CARD A RENDERIZAR -->
      <div
        id="giftcard-container"
        class="relative w-full max-w-[800px] aspect-2/1 bg-[#ffd54d] shadow-2xl overflow-hidden rounded-xl md:rounded-2xl flex"
      >
        <!-- SECCIÓN IZQUIERDA (IMAGEN DEL RESTAURANTE CON CORTE DIAGONAL Y SOMBRA 3D) -->
        <div
          class="absolute inset-y-0 left-0 w-[47%] z-20 pointer-events-none"
          style="filter: drop-shadow(10px 0px 20px rgba(0, 0, 0, 0.4));"
        >
          <div
            class="w-full h-full bg-black pointer-events-auto"
            style="clip-path: polygon(0 0, 100% 0%, 82% 100%, 0% 100%);"
          >
            <img
              id="main-giftcard-img"
              src={imgModel1.src}
              alt="Pachamama Interior"
              class="w-full h-full object-cover opacity-90 transition-opacity duration-300"
            />
            <!-- Gradiente oscuro inferior para que el texto resalte -->
            <div
              class="absolute inset-x-0 bottom-0 h-1/3 bg-linear-to-t from-black/80 to-transparent"
            >
            </div>

            <!-- Textos de la parte izquierda -->
            <div
              class="absolute bottom-4 left-6 md:bottom-6 md:left-8 flex flex-col items-start"
            >
              <p
                class="text-white text-[8px] md:text-[10px] font-body tracking-wider font-medium"
              >
                www.pachamamamilano.it
              </p>
            </div>
          </div>
        </div>

        <!-- SECCIÓN DERECHA (TEXTOS SOBRE AMARILLO) -->
        <div
          class="absolute inset-y-0 right-0 w-[60%] z-10 py-6 pr-12 pl-12 md:py-10 md:pr-16 md:pl-16 flex flex-col justify-center gap-4 md:gap-5"
        >
          <!-- Título (Arriba) -->
          <div>
            <h2
              class="text-lg md:text-[1.35rem] font-display text-black uppercase leading-none tracking-widest whitespace-nowrap mt-2"
            >
              GIFT CARD PACHAMAMA MILANO
            </h2>
          </div>

          <!-- Datos (Centro) Y Logo -->
          <div class="flex items-center justify-between pr-6 md:pr-8">
            <div class="space-y-4 md:space-y-4 flex-1">
              <div>
                <p
                  class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-black/60"
                >
                  Da
                </p>
                <p
                  class="text-sm md:text-base font-display uppercase tracking-widest text-black leading-none mt-1 line-clamp-1"
                >
                  {order.sender_name}
                </p>
              </div>

              <div>
                <p
                  class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-black/60"
                >
                  Per
                </p>
                <p
                  class="text-sm md:text-base font-display uppercase tracking-widest text-black leading-none mt-1 line-clamp-1"
                >
                  {order.receiver_name}
                </p>
              </div>
            </div>

            <!-- ESPACIO DEL LOGO (DERECHA) -->
            <div class="w-24 md:w-28 shrink-0 opacity-80 mix-blend-multiply">
              <img
                src={imgLogo.src}
                alt="Pachamama Logo"
                class="w-full h-auto object-contain"
              />
            </div>
          </div>

          <!-- Dedicatoria (Abajo) -->
          {
            order.message && (
              <div class="pt-3 md:pt-4 border-t border-black/10 pr-10 mt-1 md:mt-2">
                <p class="text-[10px] md:text-xs font-body italic leading-relaxed text-black/80 line-clamp-5 overflow-hidden text-ellipsis">
                  "{order.message}"
                </p>
              </div>
            )
          }
        </div>

        <!-- GUARDA INCA (PATTERN) MODO VERTICAL A LA DERECHA -->
        <div
          class="absolute right-0 inset-y-0 w-8 md:w-12 flex justify-center items-center overflow-hidden z-20 pointer-events-none opacity-80"
        >
          <img
            src="/images/home/pattern.png"
            alt="Pattern Decorativo"
            class="min-w-[400px] md:min-w-[600px] origin-center -rotate-90"
          />
        </div>

        <!-- ACABADOS FÍSICOS DE TARJETA REAL (REFLEJOS Y BORDES INTERNOS) -->
        <div
          class="absolute inset-0 z-30 pointer-events-none rounded-xl md:rounded-2xl ring-1 ring-inset ring-black/10"
        >
        </div>
        <div
          class="absolute inset-0 z-30 pointer-events-none rounded-xl md:rounded-2xl bg-linear-to-br from-white/40 via-transparent to-black/10 mix-blend-overlay"
        >
        </div>
      </div>

      <!-- SELECTOR DE MODELOS -->
      <div class="mt-8 flex flex-col items-center">
        <p
          class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4"
        >
          Scegli il design del ristorante
        </p>
        <div
          class="flex gap-4 overflow-x-auto pb-4 max-w-full px-4"
          style="scrollbar-width: none;"
        >
          <button
            class="model-btn active rounded-lg overflow-hidden border-[3px] border-[#ffd54d] shrink-0 w-28 md:w-32 aspect-4/3 shadow-md transition-transform hover:-translate-y-1"
          >
            <img
              src={imgModel1.src}
              alt="Model 1"
              class="w-full h-full object-cover"
            />
          </button>
          <button
            class="model-btn rounded-lg overflow-hidden border-[3px] border-transparent hover:border-gray-200 shrink-0 w-28 md:w-32 aspect-4/3 shadow-sm opacity-60 hover:opacity-100 transition-all hover:-translate-y-1"
          >
            <img
              src={imgModel2.src}
              alt="Model 2"
              class="w-full h-full object-cover"
            />
          </button>
          <button
            class="model-btn rounded-lg overflow-hidden border-[3px] border-transparent hover:border-gray-200 shrink-0 w-28 md:w-32 aspect-4/3 shadow-sm opacity-60 hover:opacity-100 transition-all hover:-translate-y-1"
          >
            <img
              src={imgModel3.src}
              alt="Model 3"
              class="w-full h-full object-cover"
            />
          </button>
        </div>
      </div>

      <!-- BOTON DE DESCARGA -->
      <div class="mt-8 flex flex-col items-center gap-4">
        <button
          id="btn-download"
          class="bg-dark hover:bg-gold hover:text-dark text-white text-xs md:text-sm uppercase font-bold px-10 py-4 md:px-12 md:py-5 tracking-widest transition-all shadow-xl hover:shadow-2xl flex items-center gap-4"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
            ></path>
          </svg>
          <span id="btn-text">Scarica Immagine (JPG)</span>
        </button>
        <a
          href="/area-cliente"
          class="text-xs font-bold text-gray-400 hover:text-dark uppercase tracking-widest underline underline-offset-4 mt-2 transition-colors"
        >
          Torna all'Area Cliente
        </a>
      </div>
    </div>
  </div>

  <script>
    import { toJpeg } from "html-to-image";
    import download from "downloadjs";

    document.addEventListener("DOMContentLoaded", () => {
      // Lógica del selector de imágenes
      const modelBtns = document.querySelectorAll(".model-btn");
      const mainImg = document.getElementById("main-giftcard-img");

      modelBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          // Remover clases visuales actives de todos
          modelBtns.forEach((b) => {
            b.classList.remove(
              "border-[#ffd54d]",
              "shadow-md",
              "active",
              "opacity-100",
            );
            b.classList.add("border-transparent", "shadow-sm", "opacity-60");
          });

          // Activar el recuadro clickeado
          btn.classList.add(
            "border-[#ffd54d]",
            "shadow-md",
            "active",
            "opacity-100",
          );
          btn.classList.remove(
            "border-transparent",
            "opacity-60",
            "hover:border-gray-200",
          );

          // Cambiar suavemente la imagen
          if (mainImg) {
            mainImg.style.opacity = "0.4"; // Baja la opacidad
            setTimeout(() => {
              const childImg = btn.querySelector("img");
              if (childImg) {
                mainImg.setAttribute("src", childImg.getAttribute("src") || "");
              }
              mainImg.style.opacity = "0.9"; // Restaura
            }, 150);
          }
        });
      });

      // Lógica oficial para descargar la gift card en HD
      const btnDownload = document.getElementById("btn-download");
      const btnText = document.getElementById("btn-text");
      const cardContainer = document.getElementById("giftcard-container");

      btnDownload?.addEventListener("click", async () => {
        if (!cardContainer) return;

        try {
          // Estado de carga
          const originalText = btnText
            ? btnText.textContent
            : "Scarica Immagine (JPG)";
          if (btnText) btnText.textContent = "Generando...";
          // if (btnDownload) btnDownload.disabled = true;

          // Mejorar la calidad de la descarga escalando a pixel ratio 2
          const dataUrl = await toJpeg(cardContainer as HTMLElement, {
            quality: 1,
            pixelRatio: 2,
            style: {
              transform: "scale(1)",
              transformOrigin: "top left",
            },
          });

          download(dataUrl, "GiftCard-Pachamama.jpg");

          // Restaurar botón
          if (btnText) btnText.textContent = originalText;
          // if (btnDownload) btnDownload.disabled = false;
        } catch (error) {
          console.error("Error generating image:", error);
          alert(
            "Si è verificato un errore durante la generazione. Riprova: " +
              error,
          );
          if (btnText) btnText.textContent = "Scarica Immagine (JPG)";
        }
      });
    });
  </script>
</Layout>
