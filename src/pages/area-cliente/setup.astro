---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const email = Astro.url.searchParams.get("email") || "";
const orderId = Astro.url.searchParams.get("order") || "";

if (!email || !orderId) {
  return Astro.redirect("/");
}
---

<Layout title="Crea Password | Pachamama Milano">
  <Header />

  <main
    class="min-h-screen pt-32 pb-20 px-4 bg-[#FBF6E6] flex items-center justify-center flex-col"
  >
    <div
      class="bg-dark p-8 md:p-12 rounded-sm shadow-2xl w-full max-w-md border border-white/5 relative overflow-hidden"
    >
      <!-- Decorative element -->
      <div
        class="absolute top-0 left-0 w-full h-1 bg-linear-to-r from-gold to-yellow-600"
      >
      </div>

      <div class="text-center mb-8">
        <h1
          class="text-3xl font-display text-gold uppercase tracking-widest mb-2"
        >
          Benvenuto
        </h1>
        <p
          class="text-gray-400 font-body text-xs leading-relaxed font-light mt-4"
        >
          Grazie per il tuo acquisto! Abbiamo creato il tuo account con l'email:<br
          />
          <strong class="text-white tracking-widest block mt-2">{email}</strong>
        </p>
        <p
          class="text-gray-400 font-body text-xs leading-relaxed font-light mt-4"
        >
          Crea una password sicura per accedere in futuro alla tua Area
          Riservata e gestire le tue Gift Card.
        </p>
      </div>

      <div class="space-y-6">
        <div>
          <label
            for="password"
            class="block text-[10px] font-bold text-gold uppercase tracking-[0.2em] mb-3"
            >Scegli una Password</label
          >
          <input
            type="password"
            id="password"
            required
            placeholder="Minimo 6 caratteri"
            class="w-full bg-white/5 border border-white/10 rounded-sm px-5 py-4 text-white placeholder:text-gray-600 focus:border-gold focus:outline-none transition-all font-body text-sm"
          />
        </div>

        <button
          id="btn-setup"
          class="w-full bg-gold hover:bg-white text-dark font-bold py-4 rounded-sm uppercase tracking-[0.2em] transition-all transform active:scale-95 shadow-lg flex justify-center items-center gap-3 text-[11px]"
          data-email={email}
          data-order={orderId}
        >
          <span>Salva e Accedi</span>
          <div
            id="loader"
            class="hidden h-4 w-4 border-2 border-dark border-t-transparent rounded-full animate-spin"
          >
          </div>
        </button>
      </div>

      <div
        id="auth-message"
        class="hidden mt-6 p-4 rounded border border-red-500/20 bg-red-500/10 text-red-400 text-[10px] font-bold uppercase tracking-widest text-center"
      >
      </div>
    </div>
  </main>

  <Footer />

  <script>
    import { supabase } from "../../lib/supabase";

    const btnSetup = document.getElementById(
      "btn-setup",
    ) as HTMLButtonElement | null;
    const passwordInput = document.getElementById(
      "password",
    ) as HTMLInputElement | null;
    const loader = document.getElementById("loader");
    const authMessage = document.getElementById("auth-message");

    btnSetup?.addEventListener("click", async () => {
      const email = btnSetup.getAttribute("data-email");
      const order = btnSetup.getAttribute("data-order");
      const password = passwordInput?.value?.trim();

      if (!email || !order || !password || password.length < 6) {
        showError("La password deve contenere almeno 6 caratteri.");
        return;
      }

      setLoading(true);

      try {
        const res = await fetch("/api/setup-password", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email, orderId: order, password }),
        });

        const data = await res.json();

        if (!res.ok) {
          throw new Error(
            data.error || "Errore durante la creazione della password",
          );
        }

        // Now login automatically
        const { error: signInError } = await supabase.auth.signInWithPassword({
          email,
          password,
        });

        if (signInError) {
          throw new Error(
            "Password salvata, ma login automatico fallito. Riprova dalla pagina di login.",
          );
        }

        // Success -> redirect to area cliente
        window.location.href = "/area-cliente";
      } catch (err: any) {
        showError(err.message);
      } finally {
        setLoading(false);
      }
    });

    passwordInput?.addEventListener("keypress", (e) => {
      if (e.key === "Enter") {
        btnSetup?.click();
      }
    });

    function showError(msg: string) {
      if (authMessage) {
        authMessage.textContent = msg;
        authMessage.classList.remove("hidden");
      }
    }

    function setLoading(isLoading: boolean) {
      if (btnSetup) btnSetup.disabled = isLoading;
      if (isLoading) {
        loader?.classList.remove("hidden");
        authMessage?.classList.add("hidden");
      } else {
        loader?.classList.add("hidden");
      }
    }
  </script>
</Layout>
