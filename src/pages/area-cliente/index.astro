---
import Layout from "../../layouts/Layout.astro";

const title = "Area Riservata | Pachamama Milano";
---

<Layout title={title}>
  <div
    class="min-h-screen bg-[#FBF6E6] flex flex-col md:flex-row font-body text-gray-900"
  >
    <!-- Sidebar / Header Mobile -->
    <header
      class="md:hidden bg-dark px-5 py-4 flex justify-between items-center z-20 relative border-b border-white/10 shadow-md"
    >
      <a href="/" class="block hover:opacity-80 transition-opacity">
        <img
          src="/logo.png"
          alt="Pachamama Milano"
          class="h-12 w-auto"
          onerror="this.src='/logo.png'"
        />
      </a>
      <a
        href="/gift-card"
        class="bg-gold text-dark px-5 py-2.5 rounded text-[10px] font-bold uppercase tracking-widest hover:bg-white transition-all shadow-sm"
        >Acquista</a
      >
    </header>

    <!-- Sidebar Desktop -->
    <aside
      class="hidden md:flex w-72 bg-dark border-r border-[#222] flex-col z-20 sticky top-0 h-screen shadow-[4px_0_24px_rgba(0,0,0,0.15)]"
    >
      <div
        class="px-8 h-[72px] shrink-0 flex items-center border-b border-white/5 bg-black/20 text-center"
      >
        <a href="/" class="block hover:opacity-80 transition-opacity w-full">
          <img
            src="/logo.png"
            alt="Pachamama Milano"
            class="h-14 w-auto mx-auto"
            onerror="this.src='/logo.png'"
          />
        </a>
      </div>
      <nav class="flex-1 px-5 py-8 space-y-2">
        <a
          href="/area-cliente"
          class="flex items-center gap-3 bg-gold text-black px-4 py-3.5 rounded font-bold text-sm shadow-sm transition-transform hover:scale-[1.02]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
            ></path>
          </svg>
          I Miei Ordini
        </a>
        <a
          href="javascript:void(0)"
          class="flex items-center gap-3 text-gray-400 hover:text-white px-4 py-3.5 rounded font-medium text-sm transition-colors opacity-50 cursor-not-allowed"
          title="In arrivo"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
            ></path>
          </svg>
          Account
        </a>

        <!-- NUOVA GIFT CARD - Moved below Account -->
        <div class="pt-6">
          <a
            href="/gift-card"
            class="flex items-center justify-center gap-2 border border-gold/40 text-gold px-4 py-3 rounded font-bold text-[11px] hover:bg-gold hover:text-dark transition-all shadow-[0_0_15px_rgba(255,213,79,0.1)] uppercase tracking-widest"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 4v16m8-8H4"></path>
            </svg>
            Nuova Gift Card
          </a>
        </div>
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col h-screen overflow-y-auto w-full relative">
      <!-- Top Header Desktop -->
      <header
        class="hidden md:flex shrink-0 bg-[#FBF6E6] shadow-sm border-b border-black/10 h-[72px] pl-10 pr-2 items-center justify-between sticky top-0 z-50"
      >
        <div class="flex items-center gap-4">
          <span
            class="bg-gold/10 text-dark px-4 py-1.5 rounded-sm text-[10px] font-bold uppercase tracking-widest border border-gold/20 shadow-sm"
            >Area Riservata</span
          >
        </div>

        <div class="relative" id="profile-dropdown-container">
          <button
            id="profile-dropdown-trigger"
            class="flex items-center gap-2 cursor-pointer hover:bg-black/5 px-2 py-1.5 rounded-lg transition-colors focus:outline-none"
          >
            <!-- Avatar Left -->
            <div
              id="avatar-initials"
              class="bg-dark text-gold border border-gold/40 font-bold w-9 h-9 rounded-full flex items-center justify-center font-display text-base tracking-tighter uppercase shadow-md shrink-0"
            >
              -
            </div>

            <!-- Text Right -->
            <div class="text-left flex items-center gap-1">
              <div class="hidden sm:block">
                <span
                  class="block text-[10px] text-gray-500 font-bold capitalize"
                  >Il mio account</span
                >
                <p
                  id="user-email"
                  class="text-sm font-bold text-black truncate max-w-[140px] leading-tight"
                >
                  Caricamento...
                </p>
              </div>
              <!-- Caret -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-3.5 w-3.5 text-black transition-transform duration-200 ml-1"
                id="profile-caret"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"></path>
              </svg>
            </div>
          </button>

          <!-- Dropdown Menu -->
          <div
            id="profile-dropdown-menu"
            class="absolute top-full mt-2 w-64 bg-white rounded-xl shadow-[0_10px_40px_rgba(0,0,0,0.1)] border border-black/5 opacity-0 invisible transform scale-95 transition-all duration-200 origin-top z-50 flex flex-col overflow-hidden"
            style="right: 0;"
          >
            <div class="p-4 border-b border-black/5 bg-gray-50/50">
              <h3 class="font-bold text-gray-900 text-sm mb-1">
                Il mio account
              </h3>
              <p
                id="dropdown-user-email"
                class="text-xs text-gray-500 truncate"
              >
                ...
              </p>
            </div>

            <div class="p-2 flex flex-col gap-1">
              <a
                href="/area-cliente"
                class="flex items-center gap-3 px-3 py-2 text-sm text-gray-700 hover:bg-[#FBF6E6] hover:text-gold rounded-md transition-colors font-medium"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4 shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                  ></path>
                </svg>
                Area riservata
              </a>
              <a
                href="/area-cliente"
                class="flex items-center gap-3 px-3 py-2 text-sm text-gray-700 hover:bg-[#FBF6E6] hover:text-gold rounded-md transition-colors font-medium"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4 shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                  ></path>
                </svg>
                Ordini
              </a>
            </div>

            <div
              class="p-2 flex flex-col border-t border-black/5 bg-gray-50/50"
            >
              <a
                href="/login"
                onclick="localStorage.removeItem('pachamama_guest_email'); supabase.auth.signOut();"
                class="flex items-center gap-3 px-3 py-2 text-sm text-red-600 hover:bg-red-50 hover:text-red-700 rounded-md transition-colors font-medium"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4 shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"
                  ></path>
                </svg>
                Logout
              </a>
            </div>
          </div>
        </div>
      </header>

      <div class="px-5 py-6 md:p-8 max-w-6xl mx-auto w-full pb-24">
        <!-- Title & Stats -->
        <div class="mb-4 md:mb-6 text-center md:text-left">
          <h1
            class="text-2xl md:text-5xl font-display font-bold text-black uppercase tracking-[0.2em]"
          >
            I Miei Ordini
          </h1>
        </div>

        <!-- Tabs -->
        <div
          class="flex gap-8 border-b border-black/10 mb-6 overflow-x-auto no-scrollbar"
        >
          <button
            class="border-b-2 border-black font-bold pb-3 text-sm text-black whitespace-nowrap uppercase tracking-widest"
            >Tutti i record (<span id="count-tutti">0</span>)</button
          >
        </div>

        <!-- Cards container -->
        <div
          id="giftcard-list"
          class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6"
        >
          <!-- Skeleton loaders -->
          <div
            class="bg-white rounded h-96 border border-black/5 animate-pulse"
          >
          </div>
          <div
            class="bg-white rounded h-96 border border-black/5 animate-pulse"
          >
          </div>
          <div
            class="bg-white rounded h-96 border border-black/5 animate-pulse hidden xl:block"
          >
          </div>
        </div>

        <!-- Empty State -->
        <div
          id="empty-state"
          class="hidden text-center py-20 bg-white rounded border border-black/5 shadow-xl"
        >
          <div
            class="bg-[#FBF6E6] w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4 border border-gold/30"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-8 w-8 text-gold"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
              ></path>
            </svg>
          </div>
          <p
            class="text-black font-display font-bold text-xl mb-2 uppercase tracking-wider"
          >
            Nessun ordine trovato
          </p>
          <p class="text-gray-500 text-sm mb-6 max-w-sm mx-auto">
            Non hai ancora acquistato una Gift Card Pachamama. Inizia a regalare
            un'esperienza unica.
          </p>
          <a
            href="/gift-card"
            class="inline-flex items-center gap-2 bg-black text-white font-bold px-6 py-3 rounded text-xs hover:bg-gold hover:text-black transition-all uppercase tracking-widest"
          >
            Richiedi Nuova Gift Card
          </a>
        </div>
      </div>
    </main>
  </div>

  <script>
    import { supabase } from "../../lib/supabase";

    const giftcardList = document.getElementById("giftcard-list");
    const emptyState = document.getElementById("empty-state");
    const userEmail = document.getElementById("user-email");
    const avatarInitials = document.getElementById("avatar-initials");
    const countTutti = document.getElementById("count-tutti");

    // Dropdown Elements
    const dropdownUserEmail = document.getElementById("dropdown-user-email");
    const dropdownTrigger = document.getElementById("profile-dropdown-trigger");
    const dropdownMenu = document.getElementById("profile-dropdown-menu");
    const caretIcon = document.getElementById("profile-caret");

    function updateUI(email: string) {
      if (userEmail) {
        userEmail.textContent = email;
      }
      if (dropdownUserEmail) {
        dropdownUserEmail.textContent = email;
      }
      if (avatarInitials) {
        avatarInitials.textContent = email.substring(0, 2).toUpperCase();
      }
    }

    if (dropdownTrigger && dropdownMenu && caretIcon) {
      dropdownTrigger.addEventListener("click", (e) => {
        e.stopPropagation();
        const isHidden = dropdownMenu.classList.contains("opacity-0");
        if (isHidden) {
          dropdownMenu.classList.remove("opacity-0", "invisible", "scale-95");
          dropdownMenu.classList.add("opacity-100", "scale-100");
          caretIcon.classList.add("-rotate-180");
        } else {
          dropdownMenu.classList.add("opacity-0", "invisible", "scale-95");
          dropdownMenu.classList.remove("opacity-100", "scale-100");
          caretIcon.classList.remove("-rotate-180");
        }
      });

      document.addEventListener("click", (e) => {
        if (
          !dropdownMenu.contains(e.target as Node) &&
          !dropdownTrigger.contains(e.target as Node)
        ) {
          dropdownMenu.classList.add("opacity-0", "invisible", "scale-95");
          dropdownMenu.classList.remove("opacity-100", "scale-100");
          caretIcon.classList.remove("-rotate-180");
        }
      });
    }

    async function checkUser() {
      // Clean up legacy guest email if it exists
      localStorage.removeItem("pachamama_guest_email");

      const {
        data: { session },
      } = await supabase.auth.getSession();
      const email = session?.user?.email?.trim().toLowerCase();

      if (!session || !email) {
        window.location.href = "/login";
        return;
      }

      updateUI(email);
      fetchGiftCards(email);
    }

    async function fetchGiftCards(email: string) {
      if (!giftcardList || !email) return;

      try {
        const cleanEmail = email.trim().toLowerCase();
        const response = await fetch(
          `/api/get-orders?email=${encodeURIComponent(cleanEmail)}`,
        );

        if (!response.ok) throw new Error("Errore nel recupero degli ordini");

        const data = await response.json();

        if (!data || data.length === 0) {
          if (giftcardList) giftcardList.innerHTML = "";
          emptyState?.classList.remove("hidden");
          if (countTutti) countTutti.textContent = "0";
          return;
        }

        if (countTutti) countTutti.textContent = data.length.toString();
        if (giftcardList) giftcardList.innerHTML = "";
        emptyState?.classList.add("hidden");

        data.forEach((card: any) => {
          const cardEl = document.createElement("div");
          cardEl.className =
            "bg-white rounded shadow-xl border border-black/5 overflow-hidden flex flex-col hover:border-gold transition-colors relative";

          let statusBadge = "";

          if (card.status === "pending") {
            statusBadge = `<div class="bg-black text-gold border border-gold/30 text-[9px] font-bold px-3 py-1.5 uppercase tracking-widest rounded shadow-sm w-max shrink-0 mt-0.5">In Lavorazione</div>`;
          } else if (card.status === "processing") {
            statusBadge = `<div class="bg-black text-gold border border-gold/30 text-[9px] font-bold px-3 py-1.5 uppercase tracking-widest rounded shadow-sm w-max shrink-0 mt-0.5">In Lavorazione</div>`;
          } else if (card.status === "confirmed") {
            statusBadge = `<div class="bg-[#2b7a2d] text-white text-[9px] font-bold px-3 py-1.5 uppercase tracking-widest rounded shadow-sm w-max shrink-0 mt-0.5">Pagamento OK</div>`;
          }

          const cardIdShort = card.id.split("-")[0].toUpperCase();
          const purchaseDate = new Date(card.created_at).toLocaleString(
            "it-IT",
            {
              day: "2-digit",
              month: "long",
              year: "numeric",
              hour: "2-digit",
              minute: "2-digit",
            },
          );

          let actionsHtml = "";

          if (card.status === "pending") {
            actionsHtml = `
              <div class="mt-auto pt-4 border-t border-black/5 space-y-3">
                <div class="bg-[#FBF6E6] rounded p-3 text-center border border-gold/20 mb-2">
                    <p class="text-[9px] text-gray-500 uppercase font-bold tracking-widest mb-1">IBAN per bonifico</p>
                    <p class="text-xs font-mono font-bold text-black break-all select-all">IT54Z3608105138283727283735</p>
                </div>
                
                <div class="flex flex-col gap-2">
                  <!-- <input type="file" id="file-${card.id}" class="hidden file-uploader" accept="image/*,.pdf" data-order="${card.id}"> -->
                  
                  <!-- <button class="upload-btn w-full bg-black text-white font-bold py-2.5 rounded text-[10px] uppercase tracking-widest hover:bg-gold hover:text-black transition-all flex justify-center items-center gap-2" data-order="${card.id}">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-8l-4-4m0 0L8 8m4-4v12" /></svg>
                    Carica Ricevuta
                  </button> -->

                  <a href="https://wa.me/393284281204?text=Ciao%2C%20ti%20mando%20il%20comprobante%20della%20mia%20Gift%20Card%20da%20%E2%82%AC${card.amount / 100}" target="_blank" class="w-full bg-[#25D366] text-white font-bold py-2.5 rounded text-[10px] uppercase tracking-widest hover:bg-[#128c7e] transition-all flex justify-center items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.878-.788-1.47-1.761-1.643-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" /></svg>
                    Invia Ricevuta tramite WhatsApp
                  </a>
                </div>
                <div id="loader-${card.id}" class="hidden text-center text-[10px] text-gold uppercase tracking-widest font-bold mt-2 animate-pulse">
                    Caricamento in corso...
                </div>
              </div>
            `;
          } else if (card.status === "processing") {
            actionsHtml = `
              <div class="mt-auto pt-4 border-t border-black/5 flex justify-center">
                 <span class="text-[10px] text-gray-500 font-bold bg-[#FBF6E6] px-4 py-2 rounded border border-black/5 uppercase tracking-widest">Ricevuta in analisi...</span>
              </div>
            `;
          } else if (card.status === "confirmed") {
            actionsHtml = `
              <div class="mt-auto pt-4 border-t border-black/5 flex justify-center italic text-[10px] text-gray-400">
                <!-- <a href="/area-cliente/scarica-gift-card?id=${card.id}" target="_blank" class="w-full bg-black text-white font-bold py-3 rounded text-[10px] uppercase tracking-widest hover:bg-gold hover:text-black transition-all flex justify-center items-center gap-2 shadow-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
                  Scarica Gift Card
                </a> -->
                La Gift Card ti è stata inviata via email
              </div>
            `;
          }

          cardEl.innerHTML = `
            <!-- Contenuto -->
            <div class="p-5 md:p-6 flex-1 flex flex-col pt-7 md:pt-8">
              <div class="flex justify-between items-start gap-3 mb-2">
                <h3 class="font-display font-bold text-black text-xl md:text-2xl uppercase tracking-wider leading-none">Ordine #${cardIdShort}</h3>
                ${statusBadge}
              </div>
              <p class="text-[9px] md:text-[10px] text-gray-500 mb-6 md:mb-8 uppercase tracking-widest italic">Acquistato: ${purchaseDate}</p>
              
              <div class="space-y-4 mb-5 md:mb-6">
                <div class="flex items-start gap-2.5 md:gap-3">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gold mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                  <div>
                    <p class="text-[8px] md:text-[9px] uppercase font-bold text-gray-400 tracking-widest">Destinatario</p>
                    <p class="text-xs md:text-sm font-bold text-black break-all uppercase">${card.receiver_name}</p>
                  </div>
                </div>
                <div class="flex items-start gap-2.5 md:gap-3">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gold mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                  <div>
                    <p class="text-[8px] md:text-[9px] uppercase font-bold text-gray-400 tracking-widest">Totale Gift Card</p>
                    <p class="text-lg md:text-xl font-display font-bold text-black">€${card.amount / 100}</p>
                  </div>
                </div>
              </div>

              ${actionsHtml}
            </div>
          `;
          if (giftcardList) giftcardList.appendChild(cardEl);
        });

        attachUploadListeners();
      } catch (err) {
        console.error("Error fetching gift cards:", err);
      }
    }

    function attachUploadListeners() {
      // Listen to the "Carica Ricevuta" generic buttons
      const uploadButtons = document.querySelectorAll(".upload-btn");
      uploadButtons.forEach((btn) => {
        btn.addEventListener("click", (e) => {
          const target = e.currentTarget as HTMLElement;
          const orderId = target.getAttribute("data-order");
          const fileInput = document.getElementById(`file-${orderId}`);
          if (fileInput) fileInput.click();
        });
      });

      // Listen to files selected in the hidden inputs
      const fileInputs = document.querySelectorAll(".file-uploader");
      fileInputs.forEach((input) => {
        input.addEventListener("change", async (e) => {
          const target = e.currentTarget as HTMLInputElement;
          const file = target.files?.[0];
          const orderId = target.getAttribute("data-order");

          if (!file || !orderId) return;

          const loader = document.getElementById(`loader-${orderId}`);
          if (loader) {
            loader.classList.remove("hidden");
            loader.textContent = `Caricamento file ${file.name}...`;
          }

          const formData = new FormData();
          formData.append("file", file);
          formData.append("orderId", orderId);

          try {
            const response = await fetch("/api/upload-receipt", {
              method: "POST",
              body: formData,
            });

            if (response.ok) {
              window.location.reload();
            } else {
              const error = await response.json();
              alert("Errore: " + (error.error || "Invio fallito"));
              if (loader) loader.classList.add("hidden");
            }
          } catch (err) {
            console.error(err);
            alert("Errore di connessione.");
            if (loader) loader.classList.add("hidden");
          }
        });
      });
    }

    checkUser();
  </script>
</Layout>
