---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const title = "Pannello Admin | Pachamama Milano";
---

<Layout title={title}>
  <Header />

  <main class="min-h-screen pt-44 pb-20 px-4 md:px-12 bg-white text-dark">
    <div class="max-w-7xl mx-auto">
      <div
        class="flex flex-col md:flex-row justify-between items-center mb-12 gap-6 bg-dark p-10 rounded-3xl shadow-2xl"
      >
        <div>
          <h1 class="text-5xl font-display text-gold uppercase tracking-widest">
            Admin Pachamama
          </h1>
          <p class="text-gray-400 font-body text-sm italic">
            Gestione ordini e validazione bonifici
          </p>
        </div>
        <div class="flex gap-4">
          <div
            class="bg-white/5 px-6 py-3 rounded-xl border border-white/10 text-center"
          >
            <p
              class="text-[10px] text-gold uppercase font-bold tracking-widest mb-1"
            >
              Ordini Oggi
            </p>
            <p id="stats-today" class="text-2xl font-display text-white italic">
              --
            </p>
          </div>
        </div>
      </div>

      <!-- Tabla de Pedidos -->
      <div
        class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden"
      >
        <div
          class="p-8 border-b border-gray-50 flex justify-between items-center"
        >
          <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest">
            Lista Ordini Gift Card
          </h3>
          <button
            id="refresh-btn"
            class="text-dark hover:text-gold transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
              ></path></svg
            >
          </button>
        </div>

        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead class="bg-gray-50 border-b border-gray-100 italic">
              <tr>
                <th
                  class="px-8 py-4 text-[10px] font-bold uppercase text-gray-400 tracking-wider"
                  >Data / ID</th
                >
                <th
                  class="px-8 py-4 text-[10px] font-bold uppercase text-gray-400 tracking-wider"
                  >Cliente (Acquirente)</th
                >
                <th
                  class="px-8 py-4 text-[10px] font-bold uppercase text-gray-400 tracking-wider"
                  >Destinatario</th
                >
                <th
                  class="px-8 py-4 text-[10px] font-bold uppercase text-gray-400 tracking-wider"
                  >Importo</th
                >
                <th
                  class="px-8 py-4 text-[10px] font-bold uppercase text-gray-400 tracking-wider"
                  >Comprobante</th
                >
                <th
                  class="px-8 py-4 text-[10px] font-bold uppercase text-gray-400 tracking-wider"
                  >Stato / Azioni</th
                >
              </tr>
            </thead>
            <tbody
              id="admin-orders-list"
              class="divide-y divide-gray-50 font-body text-sm text-dark"
            >
              <!-- Loading State -->
              <tr
                ><td
                  colspan="6"
                  class="px-8 py-20 text-center text-gray-400 italic"
                  >Caricamento ordini...</td
                ></tr
              >
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>

  <Footer />

  <!-- Lightbox for Receipt (Hidden) -->
  <div
    id="lightbox"
    class="hidden fixed inset-0 bg-dark/95 z-200 p-10 items-center justify-center"
  >
    <button
      id="close-lightbox"
      class="absolute top-10 right-10 text-white text-4xl hover:text-gold transition-colors"
      >&times;</button
    >
    <img
      id="lightbox-img"
      src=""
      alt="Comprobante"
      class="max-w-full max-h-full rounded-xl shadow-2xl shadow-black"
    />
  </div>

  <script>
    import { supabase } from "../../lib/supabase";

    const ordersList = document.getElementById("admin-orders-list");
    const refreshBtn = document.getElementById("refresh-btn");
    const lightbox = document.getElementById("lightbox");
    const lightboxImg = document.getElementById(
      "lightbox-img",
    ) as HTMLImageElement;
    const closeLightbox = document.getElementById("close-lightbox");

    async function fetchOrders() {
      if (!ordersList) return;

      const { data, error } = await supabase
        .from("gift_cards")
        .select("*")
        .order("created_at", { ascending: false });

      if (error || !data) {
        ordersList.innerHTML =
          '<tr><td colspan="6" class="px-8 py-20 text-center text-red-400">Errore nel caricamento</td></tr>';
        return;
      }

      ordersList.innerHTML = "";
      data.forEach((order) => {
        const row = document.createElement("tr");
        row.className = "hover:bg-gray-50/50 transition-colors";

        let statusBadge = "";
        if (order.status === "pending")
          statusBadge =
            '<span class="px-3 py-1 text-[10px] font-bold uppercase bg-yellow-100 text-yellow-600 rounded-full">Pendiente</span>';
        else if (order.status === "processing")
          statusBadge =
            '<span class="px-3 py-1 text-[10px] font-bold uppercase bg-blue-100 text-blue-600 rounded-full">In Verifica</span>';
        else if (order.status === "confirmed")
          statusBadge =
            '<span class="px-3 py-1 text-[10px] font-bold uppercase bg-green-100 text-green-600 rounded-full">Confermato</span>';
        else if (order.status === "cancelled")
          statusBadge =
            '<span class="px-3 py-1 text-[10px] font-bold uppercase bg-red-100 text-red-600 rounded-full">Annullato</span>';

        row.innerHTML = `
          <td class="px-8 py-6">
            <p class="font-bold text-xs uppercase tracking-tighter">#${order.id.split("-")[0]}</p>
            <p class="text-[10px] text-gray-400">${new Date(order.created_at).toLocaleDateString()}</p>
          </td>
          <td class="px-8 py-6">
            <p class="font-semibold">${order.sender_name}</p>
            <p class="text-[10px] text-gray-400">${order.sender_email}</p>
          </td>
          <td class="px-8 py-6 text-2xl font-display uppercase italic tracking-widest text-dark/70">
            ${order.receiver_name.split(" ")[0]}
          </td>
          <td class="px-8 py-6">
            <p class="text-xl font-display text-dark">€${order.amount / 100}</p>
          </td>
          <td class="px-8 py-6">
            ${
              order.receipt_url
                ? `
                <button class="view-receipt text-gold hover:text-dark text-[10px] font-bold uppercase tracking-widest bg-gold/10 px-3 py-1 rounded transition-all" data-url="${order.receipt_url}">Vedi Foto</button>
            `
                : '<span class="text-[8px] text-gray-300 uppercase">Senza comprovante</span>'
            }
          </td>
          <td class="px-8 py-6">
            <div class="flex items-center gap-4">
               ${statusBadge}
               ${
                 order.status === "processing" || order.status === "pending"
                   ? `
                 <div class="flex gap-2">
                    <button class="admin-action text-green-500 hover:bg-green-50 p-1 rounded" data-id="${order.id}" data-action="confirm">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    </button>
                    <button class="admin-action text-red-400 hover:bg-red-50 p-1 rounded" data-id="${order.id}" data-action="cancel">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>
                 </div>
               `
                   : ""
               }
            </div>
          </td>
        `;
        ordersList.appendChild(row);
      });

      // Event listeners for actions
      document.querySelectorAll(".admin-action").forEach((btn) => {
        btn.addEventListener("click", async (e) => {
          const b = e.currentTarget as HTMLButtonElement;
          const id = b.dataset.id;
          const action = b.dataset.action;
          if (
            confirm(
              `Sicuro di voler ${action === "confirm" ? "CONFERMARE" : "ANNULLARE"} questo ordine?`,
            )
          ) {
            await sendAction(id!, action!);
          }
        });
      });

      document.querySelectorAll(".view-receipt").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          const b = e.currentTarget as HTMLButtonElement;
          const url = b.dataset.url;
          if (url && lightboxImg) {
            lightboxImg.src = url;
            lightbox?.classList.remove("hidden");
          }
        });
      });
    }

    async function sendAction(orderId: string, action: string) {
      try {
        const res = await fetch("/api/admin-action", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ orderId, action }),
        });
        if (res.ok) fetchOrders();
        else alert("Errore nellazione admin");
      } catch (err) {
        alert("Errore di connessione");
      }
    }

    closeLightbox?.addEventListener("click", () =>
      lightbox?.classList.add("hidden"),
    );
    refreshBtn?.addEventListener("click", fetchOrders);

    // Auto-fetch on load
    fetchOrders();
  </script>
</Layout>
