---
import AdminLayout from "../../layouts/AdminLayout.astro";
const title = "Dashboard | Pachamama Admin";
---

<AdminLayout title={title}>
  <div class="space-y-8 max-w-7xl mx-auto">
    <div
      class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden"
    >
      <!-- HEADER -->
      <div
        class="border-b border-gray-100 p-8 flex flex-col md:flex-row items-baseline justify-between gap-6 bg-gray-50/50"
      >
        <div>
          <h1 class="text-3xl font-display uppercase tracking-widest text-dark">
            Dashboard
          </h1>
          <p class="text-gray-500 font-body text-sm mt-1">
            Panoramica del tuo sistema Pachamama Milano.
          </p>
        </div>
        <div class="flex items-center gap-4 text-xs font-bold text-gray-400">
          <span
            class="bg-white py-1 px-3 border border-gray-100 rounded-lg shadow-sm"
            >Da: 01/03/2026</span
          >
          <span
            class="bg-white py-1 px-3 border border-gray-100 rounded-lg shadow-sm"
            >A: 31/03/2026</span
          >
        </div>
      </div>

      <!-- ESTADISTICAS -->
      <div
        class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-gray-100"
      >
        <!-- Tarjeta 1 - GiBravo Style Circulo Azul -->
        <div
          class="p-8 flex flex-col items-center justify-between h-64 hover:bg-gray-50/30 transition-colors"
        >
          <h3
            class="text-[11px] text-gray-500 font-bold uppercase tracking-widest w-full text-left"
          >
            TOTALE ORDINI
          </h3>

          <div
            class="w-32 h-32 rounded-full border-12 border-dark flex items-center justify-center my-4"
          >
            <span class="text-3xl font-display text-dark" id="stat-total-orders"
              >-</span
            >
          </div>

          <p class="text-sm font-bold text-dark w-full text-center">
            Ordini Totali Ricevuti
          </p>
        </div>

        <!-- Tarjeta 2 - GiBravo Style Informacion de Ventas -->
        <div
          class="p-8 flex flex-col justify-between h-64 hover:bg-gray-50/30 transition-colors"
        >
          <div
            class="flex justify-between items-center bg-gold text-dark w-10 h-10 rounded-full mb-4 shrink-0 mx-auto"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5 mx-auto"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"
              ></path></svg
            >
          </div>

          <h3
            class="text-[11px] text-gray-500 font-bold uppercase tracking-widest text-center mb-4"
          >
            GIFT CARDS IN ATTESA
          </h3>

          <div class="flex-1 flex flex-col items-center justify-center">
            <p
              class="text-5xl font-display text-dark mb-2"
              id="stat-pending-orders"
            >
              -
            </p>
            <p
              class="text-[10px] uppercase tracking-widest font-bold text-gray-400"
            >
              Verifiche Pendenti
            </p>
          </div>
        </div>

        <!-- Tarjeta 3 - GiBravo Style Incasso -->
        <div
          class="p-8 flex flex-col items-center justify-between h-64 hover:bg-gray-50/30 transition-colors"
        >
          <h3
            class="text-[11px] text-gray-500 font-bold uppercase tracking-widest w-full text-left"
          >
            TOTALE VENDITE
          </h3>

          <div
            class="w-32 h-32 rounded-full border-12 border-gold/30 flex items-center justify-center my-4 relative"
          >
            <div
              class="absolute inset-0 border-12 border-dark rounded-full transition-all"
              style="clip-path: polygon(0 0, 100% 0, 100% 100%, 0% 100%);"
            >
            </div>
            <span
              class="text-3xl font-display text-dark"
              id="stat-total-revenue">-</span
            >
          </div>

          <p
            class="text-[10px] font-bold text-gray-400 w-full text-center uppercase tracking-widest"
          >
            Incasso Accumulato
          </p>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { supabase } from "../../lib/supabase";

    async function loadDashboardStats() {
      const {
        data: { session },
      } = await supabase.auth.getSession();
      if (!session) return;

      try {
        const res = await fetch(
          `/api/admin/get-all-orders?token=${session.access_token}`,
        );
        if (!res.ok) return;
        const data = await res.json();

        const elTotal = document.getElementById("stat-total-orders");
        const elPending = document.getElementById("stat-pending-orders");
        const elRevenue = document.getElementById("stat-total-revenue");

        if (elTotal) elTotal.innerText = data.length.toString();

        const pendingCount = data.filter(
          (o: any) => o.status === "processing",
        ).length;
        if (elPending) elPending.innerText = pendingCount.toString();

        const totalRevenue = data.reduce(
          (acc: number, curr: any) => acc + curr.amount / 100,
          0,
        );
        if (elRevenue) elRevenue.innerText = `€${totalRevenue}`;
      } catch (e) {
        console.error(e);
      }
    }

    loadDashboardStats();
  </script>
</AdminLayout>
