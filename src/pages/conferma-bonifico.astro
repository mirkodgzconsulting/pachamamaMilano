---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const orderId = Astro.url.searchParams.get("id");

if (!orderId) {
  return Astro.redirect("/gift-card");
}
---

<Layout title="Conferma Bonifico | Pachamama Milano">
  <Header />

  <main class="min-h-screen pt-28 pb-12 px-4 bg-white">
    <div class="max-w-xl mx-auto">
      <!-- Contenitore Unico Compatto -->
      <div
        class="bg-dark rounded-lg shadow-xl border border-white/5 overflow-hidden"
      >
        <!-- Header -->
        <div class="p-6 border-b border-white/5 text-center">
          <div class="flex justify-center mb-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-8 w-8 text-gold"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h1
            class="text-2xl font-display text-gold uppercase tracking-widest mb-2"
          >
            Quasi fatto
          </h1>
          <p
            class="text-gray-400 font-body text-[13px] leading-relaxed max-w-sm mx-auto"
          >
            Effettua un <strong class="text-white">bonifico istantaneo</strong> con
            i seguenti dati:
          </p>
        </div>

        <!-- Dati Bancari -->
        <div class="px-8 py-5 bg-black/20 space-y-4 border-b border-white/5">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label
                class="text-[9px] text-gold uppercase font-bold tracking-widest block mb-1"
                >Beneficiario</label
              >
              <p class="text-white font-medium text-sm leading-tight">
                Edith Cristina Rodríguez Vásquez
                <span class="block text-[10px] text-gray-400 font-normal mt-0.5"
                  >Bancó Posta Pay</span
                >
              </p>
            </div>
            <div>
              <label
                class="text-[9px] text-gold uppercase font-bold tracking-widest block mb-1"
                >Causale</label
              >
              <p
                class="text-white font-mono bg-gold/10 px-2 py-1 rounded text-[10px] sm:text-[11px] border border-gold/20 inline-block"
              >
                Gift Card Pachamama
              </p>
            </div>
          </div>

          <div>
            <label
              class="text-[9px] text-gold uppercase font-bold tracking-widest block mb-1"
              >IBAN</label
            >
            <div
              id="copy-iban-btn"
              class="flex items-center justify-between text-white font-mono text-sm sm:text-base tracking-wider break-all bg-white/5 p-3 rounded border border-white/10 select-all cursor-pointer hover:bg-white/10 hover:border-gold/50 transition-all group"
              title="Copia IBAN"
            >
              <span id="iban-text">IT54Z3608105138283727283735</span>
              <div
                class="flex items-center gap-2 opacity-50 group-hover:opacity-100 transition-opacity"
              >
                <span
                  id="copy-feedback"
                  class="text-[9px] uppercase font-bold text-gold opacity-0 transition-opacity"
                  >Copiato</span
                >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4 sm:h-5 sm:w-5 text-gray-400 group-hover:text-gold transition-colors"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
                  ></path>
                </svg>
              </div>
            </div>
          </div>
        </div>

        <!-- Caricamento -->
        <div class="p-8">
          <div id="upload-container" class="space-y-4">
            <div class="text-center">
              <h2
                class="text-sm font-display text-white uppercase tracking-widest mb-1"
              >
                Carica il comprobante
              </h2>
              <p class="text-[10px] text-gray-500">
                Allega lo screenshot della transazione.
              </p>
            </div>

            <div
              id="drop-zone"
              class="border border-dashed border-white/10 rounded p-6 text-center transition-all cursor-pointer hover:bg-white/5 hover:border-gold group"
            >
              <input
                type="file"
                id="receipt-file"
                class="hidden"
                accept="image/*,.pdf"
              />

              <div id="upload-prompt" class="space-y-2">
                <div
                  class="bg-white/5 w-10 h-10 rounded-full flex items-center justify-center mx-auto transition-transform group-hover:scale-105"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-5 w-5 text-gold"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.5"
                      d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-8l-4-4m0 0L8 8m4-4v12"
                    ></path>
                  </svg>
                </div>
                <p class="text-[11px] text-gray-300">Clicca o trascina qui</p>
              </div>

              <!-- Anteprima -->
              <div id="file-info" class="hidden space-y-2">
                <div
                  class="bg-white/5 p-2 rounded border border-gold/20 flex items-center justify-between"
                >
                  <div class="flex items-center gap-2 overflow-hidden">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-4 w-4 text-green-500 shrink-0"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                      ></path>
                    </svg>
                    <span
                      id="file-name"
                      class="text-[10px] text-white truncate font-mono tracking-tight"
                    ></span>
                  </div>
                  <button
                    id="remove-file"
                    class="text-red-400 hover:text-red-500"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-4 w-4"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                  </button>
                </div>
              </div>
            </div>

            <button
              id="send-payment"
              class="w-full bg-gold hover:bg-white text-dark font-bold py-3.5 rounded text-xs uppercase tracking-widest transition-all disabled:opacity-30 flex items-center justify-center gap-2 opacity-0 translate-y-1"
              disabled
            >
              <span>Invia Segnalazione</span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-4 w-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Loading Overlay -->
      <div
        id="loading-overlay"
        class="hidden fixed inset-0 bg-dark/95 backdrop-blur-md z-100 flex-col items-center justify-center text-white"
      >
        <div
          class="h-10 w-10 border-2 border-gold border-t-transparent rounded-full animate-spin mb-4"
        >
        </div>
        <h2 class="font-display uppercase tracking-widest text-gold text-xl">
          Invio in corso
        </h2>
      </div>
    </div>
  </main>

  <Footer />

  <script define:vars={{ orderId }}>
    const dropZone = document.getElementById("drop-zone");
    const fileInput = document.getElementById("receipt-file");
    const fileInfo = document.getElementById("file-info");
    const uploadPrompt = document.getElementById("upload-prompt");
    const fileNameDisplay = document.getElementById("file-name");
    const removeFileBtn = document.getElementById("remove-file");
    const sendBtn = document.getElementById("send-payment");
    const loadingOverlay = document.getElementById("loading-overlay");

    const copyIbanBtn = document.getElementById("copy-iban-btn");
    const ibanText = document.getElementById("iban-text");
    const copyFeedback = document.getElementById("copy-feedback");

    copyIbanBtn?.addEventListener("click", () => {
      navigator.clipboard.writeText(ibanText.innerText.trim());
      copyFeedback.classList.remove("opacity-0");
      setTimeout(() => {
        copyFeedback.classList.add("opacity-0");
      }, 2000);
    });

    let selectedFile = null;

    dropZone.addEventListener("click", (e) => {
      if (!e.target.closest("#remove-file")) fileInput.click();
    });

    fileInput.addEventListener("change", (e) => {
      handleFiles(e.target.files);
    });

    dropZone.addEventListener("dragover", (e) => {
      e.preventDefault();
      dropZone.classList.add("border-gold", "bg-white/5");
    });

    dropZone.addEventListener("dragleave", () => {
      dropZone.classList.remove("border-gold", "bg-white/5");
    });

    dropZone.addEventListener("drop", (e) => {
      e.preventDefault();
      dropZone.classList.remove("border-gold", "bg-white/5");
      handleFiles(e.dataTransfer.files);
    });

    function handleFiles(files) {
      if (files.length > 0) {
        selectedFile = files[0];
        fileNameDisplay.innerText = selectedFile.name;
        uploadPrompt.classList.add("hidden");
        fileInfo.classList.remove("hidden");
        fileInfo.style.display = "block";
        sendBtn.disabled = false;
        sendBtn.classList.remove("opacity-0", "translate-y-1");
      }
    }

    removeFileBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      selectedFile = null;
      fileInput.value = "";
      fileInfo.classList.add("hidden");
      fileInfo.style.display = "none";
      uploadPrompt.classList.remove("hidden");
      sendBtn.disabled = true;
      sendBtn.classList.add("opacity-0", "translate-y-1");
    });

    sendBtn.addEventListener("click", async () => {
      if (!selectedFile) return;
      loadingOverlay.classList.remove("hidden");
      loadingOverlay.style.display = "flex";
      sendBtn.disabled = true;

      const formData = new FormData();
      formData.append("file", selectedFile);
      formData.append("orderId", orderId);

      try {
        const response = await fetch("/api/upload-receipt", {
          method: "POST",
          body: formData,
        });

        if (response.ok) {
          window.location.href = "/area-cliente?status=processing";
        } else {
          const error = await response.json();
          alert("Errore: " + (error.error || "Invio fallito"));
          loadingOverlay.classList.add("hidden");
          loadingOverlay.style.display = "none";
          sendBtn.disabled = false;
        }
      } catch (err) {
        console.error(err);
        alert("Errore di connessione.");
        loadingOverlay.classList.add("hidden");
        loadingOverlay.style.display = "none";
        sendBtn.disabled = false;
      }
    });
  </script>
</Layout>
